# ── Auth ─────────────────────────────────────────────────────────────────────
# Shared secret between the Tauri app and this server.
# Set to any long random string, then configure the same value in the app's
# sync settings.  If unset the server runs open (dev mode only).
CK_SYNC_TOKEN=change-me-to-a-long-random-secret

# ── Storage ───────────────────────────────────────────────────────────────────
# SQLite database path (default: ./chronicle_keeper_sync.db next to the process)
CK_DB_PATH=./chronicle_keeper_sync.db

# ── Network ───────────────────────────────────────────────────────────────────
CK_HOST=0.0.0.0
CK_PORT=8080

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins.  Use "*" for dev; set to your exact origin
# in production if you serve the app from a known domain.
CK_CORS_ORIGINS=*

# ── Logging ───────────────────────────────────────────────────────────────────
# Set to 1 for verbose debug output
CHRONICLE_DEBUG=0
